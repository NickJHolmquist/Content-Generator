# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Typefully
# Get this from typefully.com → Settings → API
TYPEFULLY_API_KEY=...

# Kit (formerly ConvertKit)
# Get this from kit.com → Settings → Developer → API Keys
KIT_API_KEY=...

# Pipeline config
NEWSLETTER_DIR=./newsletter/inbox       # Written to by fetch-newsletter.js
PROCESSED_DIR=./newsletter/processed    # Archived after processing
THREADS_PER_NEWSLETTER=5                # How many thread drafts to generate per week
SCHEDULE_OFFSET_DAYS=1                  # First post starts N days from today

# Set to "true" to run without posting to Typefully (for testing)
DRY_RUN=true
