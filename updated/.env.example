# Anthropic
# Get this from platform.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Typefully
# Get your API key and Social Set ID from typefully.com → Settings → API
# Enable Development mode to see your Social Set ID in the UI
TYPEFULLY_API_KEY=...
TYPEFULLY_SOCIAL_SET_ID=...

# Threads
# Access token from your Threads OAuth app
# Needs threads_basic and threads_content_publish permissions
THREADS_ACCESS_TOKEN=...

# Pipeline config
NEWSLETTER_DIR=./newsletter/inbox       # Drop your .txt file here each week
PROCESSED_DIR=./newsletter/processed    # Archived automatically after processing
SCHEDULE_OFFSET_DAYS=1                  # First post scheduled N days from today

# CTA reply posted under each thread ~2 hours after it goes live
# Leave blank to disable CTA replies entirely
CTA_TEXT=If this resonated, I go deeper on this every week in the newsletter. Link in bio.
